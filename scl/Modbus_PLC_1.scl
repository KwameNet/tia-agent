FUNCTION "Modbus" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

VAR_TEMP
    Done        : Bool;
    Busy        : Bool;
    Error       : Bool;
    Status      : Word;
    Data_Addr   : UDInt;
    Data_Length : UInt;
    Data_ptr    : Array[0..23] of UInt;
    MBDone      : Bool;
    SeqCounter  : Int;
END_VAR

BEGIN
    // Initialise serial port on first PLC scan
    IF "FirstScan" THEN
        "MB_COMM_LOAD_DB"(REQ    := TRUE,
                          PORT   := "Local~CB_1241_(RS485)",
                          BAUD   := 9600,
                          PARITY := 2,
                          MB_DB  := "MB_MASTER_DB");
    END_IF;

    // Execute Modbus master transaction (enable: Clock_2Hz, REQ: Clock_1Hz)
    IF "Clock_2Hz" THEN
        "MB_MASTER_DB"(REQ       := "Clock_1Hz",
                       MB_ADDR   := 1,
                       MODE      := 0,
                       DATA_ADDR := Data_Addr,
                       DATA_LEN  := Data_Length,
                       DATA_PTR  := "Modbus_Raw".transfer,
                       DONE      => MBDone,
                       BUSY      => Busy,
                       ERROR     => Error,
                       STATUS    => Status);
    END_IF;

END_FUNCTION
